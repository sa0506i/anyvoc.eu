<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anyvoc — Coming Soon</title>
    <meta
      name="description"
      content="Anyvoc — Learn every word. Anywhere. Anytime. The app launches soon."
    />
    <meta name="theme-color" content="#050D1A" />
    <link rel="alternate" hreflang="de" href="/" />
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="alternate" hreflang="x-default" href="/" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="hero">
      <div class="logo-container">
        <img src="/logo.png" alt="Anyvoc" width="200" height="200" />
      </div>

      <h1>Welcome to Anyvoc</h1>
      <p class="tagline">
        Build a personal vocabulary from anything you read.
        Your data stays on your device.
      </p>
      <div class="status-badge">Coming Soon</div>
    </main>

    <footer>
      <div class="footer-inner">
        <p>© 2026 Anyvoc. All rights reserved.</p>
        <nav class="footer-links" aria-label="Legal">
          <a href="/en/legal/imprint.html">Imprint</a>
          <a href="/en/legal/privacy.html">Privacy</a>
          <a href="/en/legal/terms.html">Terms</a>
          <a href="/en/legal/faq.html">FAQ</a>
        </nav>
        <div class="lang-picker" aria-label="Language">
          <a href="/en/" class="active" aria-current="true">English</a>
          <span class="sep" aria-hidden="true">|</span>
          <a href="/">Deutsch</a>
        </div>
      </div>
    </footer>
  </body>
</html>
